# ==========================================
# Frontend Environment Variables (Vercel)
# ==========================================
# Point this to your Render backend URL (no trailing slash)
# Example: https://symbols-academy-api.onrender.com
VITE_API_URL=http://localhost:5001

# ==========================================
# Backend Environment Variables (Render)
# ==========================================
NODE_ENV=production
PORT=5001

# MongoDB Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/symbols_academy?retryWrites=true&w=majority

# JWT Authentication Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Cloudinary Setup for Media
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# The URL of your deployed Vercel frontend (no trailing slash)
# Example: https://symbols-academy.vercel.app
FRONTEND_URL=http://localhost:5173
